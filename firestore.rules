rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 관리자 확인 함수 (dwceo09@gmail.com)
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == "dwceo09@gmail.com" && request.auth.token.email_verified == true);
    }

    // 신청자 정보 유효성 검사
    function isValidApplicant(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.phone is string && data.phone.size() > 0 &&
             data.address is string && data.address.size() > 0 &&
             data.createdAt is string;
    }

    match /applicants/{applicantId} {
      // 누구나 신청(쓰기)은 가능하지만, 데이터 검증 필수
      allow create: if isValidApplicant(request.resource.data);
      
      // 관리자만 전체 목록 조회 및 개별 데이터 읽기 가능
      allow read, list: if isAdmin();
      
      // 수정 및 삭제는 기본적으로 금지 (필요 시 관리자만 허용)
      allow update, delete: if isAdmin();
    }
  }
}
